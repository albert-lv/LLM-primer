---
import { getCollection } from 'astro:content';
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro';
import { buildCitedByIndex } from '../../../lib/cited-by';

const domainLabels: Record<string, string> = {
  architecture: 'Architecture',
  pretraining: 'Pretraining',
  alignment: 'Alignment',
  inference: 'Inference',
  applications: 'Applications',
  evaluation: 'Evaluation',
  safety: 'Safety',
  multimodal: 'Multimodal',
  reasoning: 'Reasoning',
  'long-context': 'Long Context',
  moe: 'Mixture of Experts',
  uncategorized: 'Uncategorized',
};

export async function getStaticPaths() {
  const papers = await getCollection('papers');
  const docs = await getCollection('docs');

  const articleRefs = docs.map((doc) => ({
    slug: doc.slug,
    papers: doc.data.papers ?? [],
  }));
  const citedBy = buildCitedByIndex(articleRefs);

  return papers
    .filter((p) => !p.data.inbox)
    .map((paper) => ({
      params: { id: paper.data.id },
      props: {
        paper: paper.data,
        citedByArticles: citedBy.get(paper.data.id) ?? [],
      },
    }));
}

const { paper, citedByArticles } = Astro.props;
const docs = await getCollection('docs');
const allPapers = await getCollection('papers');
const publishedPapers = allPapers.filter((p) => !p.data.inbox);

const relatedPapers = publishedPapers
  .filter((p) => p.data.id !== paper.id)
  .filter((p) => (p.data.domains ?? []).some((d) => (paper.domains ?? []).includes(d)))
  .sort((a, b) => (b.data.year ?? 0) - (a.data.year ?? 0))
  .slice(0, 6);

const coCitedPapers = publishedPapers
  .filter((p) => p.data.id !== paper.id)
  .filter((p) => citedByArticles.some((slug) => {
    const doc = docs.find((d) => d.slug === slug);
    return doc?.data.papers?.includes(p.data.id);
  }))
  .slice(0, 4);
---

<StarlightPage
  frontmatter={{
    title: paper.title ?? paper.id,
    description: paper.tldr_en,
  }}
>
  <div class="paper-detail">
    {paper.authors && paper.authors.length > 0 && (
      <p class="authors">
        <strong>Authors:</strong>
        {paper.authors.join(', ')}
        {paper.year && ` (${paper.year})`}
      </p>
    )}

    {paper.arxiv_id && (
      <p>
        <strong>arXiv:</strong>
        <a href={`https://arxiv.org/abs/${paper.arxiv_id}`} target="_blank" rel="noopener">
          {paper.arxiv_id}
        </a>
      </p>
    )}

    {paper.doi && (
      <p>
        <strong>DOI:</strong>
        <a href={`https://doi.org/${paper.doi}`} target="_blank" rel="noopener">
          {paper.doi}
        </a>
      </p>
    )}

    {paper.domains && paper.domains.length > 0 && (
      <section>
        <h2>Domains</h2>
        <div class="domain-tags">
          {paper.domains.map((d) => (
            <span class="domain-tag">{domainLabels[d] ?? d}</span>
          ))}
        </div>
      </section>
    )}

    <section class="tldr-section">
      <h2>TLDR (English)</h2>
      <p>{paper.tldr_en}</p>
    </section>

    <section class="tldr-section">
      <h2>TLDR（中文）</h2>
      <p>{paper.tldr_zh}</p>
    </section>

    {citedByArticles.length > 0 && (
      <section>
        <h2>Appears in These Articles</h2>
        <ul>
          {citedByArticles.map((slug) => {
            const doc = docs.find((d) => d.slug === slug);
            const title = doc?.data.title ?? slug;
            return (
              <li>
                <a href={`/en/${slug}/`}>{title}</a>
              </li>
            );
          })}
        </ul>
      </section>
    )}

    {coCitedPapers.length > 0 && (
      <section>
        <h2>Co-cited Papers</h2>
        <p class="section-hint">These papers appear in the same articles as this one</p>
        <ul class="related-list">
          {coCitedPapers.map((p) => (
            <li>
              <a href={`/en/papers/${p.data.id}/`}>{p.data.title ?? p.data.id}</a>
              <span class="related-meta">{p.data.authors?.[0]}{p.data.authors && p.data.authors.length > 1 ? ' et al.' : ''} {p.data.year ? `(${p.data.year})` : ''}</span>
            </li>
          ))}
        </ul>
      </section>
    )}

    {relatedPapers.length > 0 && (
      <section>
        <h2>Related Papers</h2>
        <p class="section-hint">Other papers in the same domain</p>
        <ul class="related-list">
          {relatedPapers.map((p) => (
            <li>
              <a href={`/en/papers/${p.data.id}/`}>{p.data.title ?? p.data.id}</a>
              <span class="related-meta">{p.data.authors?.[0]}{p.data.authors && p.data.authors.length > 1 ? ' et al.' : ''} {p.data.year ? `(${p.data.year})` : ''}</span>
              <div class="related-domains">
                {(p.data.domains ?? []).map((d) => (
                  <span class="domain-tag small">{domainLabels[d] ?? d}</span>
                ))}
              </div>
            </li>
          ))}
        </ul>
      </section>
    )}
  </div>
</StarlightPage>

<style>
  .paper-detail p {
    margin: 0.5rem 0;
  }
  .authors {
    color: var(--sl-color-gray-2);
  }
  .tldr-section {
    margin: 1.5rem 0;
    padding: 1rem;
    background: var(--sl-color-gray-6, #f9f9f9);
    border-radius: 0.5rem;
    border-left: 3px solid var(--sl-color-accent, #0070f3);
  }
  .tldr-section h2 {
    margin-top: 0;
    font-size: 1rem;
  }
  .domain-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
  }
  .domain-tag {
    display: inline-block;
    padding: 0.15rem 0.6rem;
    border-radius: 4px;
    background: var(--sl-color-gray-6, #f0f0f0);
    color: var(--sl-color-gray-2, #555);
    font-size: 0.8rem;
  }
  .domain-tag.small {
    font-size: 0.7rem;
    padding: 0.1rem 0.4rem;
  }
  .section-hint {
    color: var(--sl-color-gray-3, #888);
    font-size: 0.85rem;
    margin-top: -0.5rem;
    margin-bottom: 0.75rem;
  }
  .related-list {
    list-style: none;
    padding: 0;
  }
  .related-list li {
    margin-bottom: 0.75rem;
    padding: 0.6rem;
    border: 1px solid var(--sl-color-gray-5, #eee);
    border-radius: 0.4rem;
  }
  .related-list a {
    font-weight: 500;
  }
  .related-meta {
    display: block;
    color: var(--sl-color-gray-3, #666);
    font-size: 0.8rem;
    margin-top: 0.15rem;
  }
  .related-domains {
    display: flex;
    flex-wrap: wrap;
    gap: 0.25rem;
    margin-top: 0.3rem;
  }
</style>
