---
import { getCollection } from 'astro:content';

const isEn = Astro.currentLocale === 'en';
const docs = await getCollection('docs', ({ data, id }) => {
  if (data.status !== 'published' || !data.updated) return false;
  return isEn ? id.startsWith('en/') : !id.startsWith('en/');
});
const recent = docs
  .sort((a, b) => Number(b.data.updated) - Number(a.data.updated))
  .slice(0, 6);
function href(id: string) {
  if (id === 'index' || id === 'en/index') return isEn ? '/en/' : '/';
  return isEn ? `/en/${id.replace(/^en\//, '')}/` : `/${id}/`;
}
---

<ul class="recent-articles">
  {recent.map((doc) => (
    <li>
      <a href={href(doc.id)}>{doc.data.title}</a>
      <span>{doc.data.updated?.toISOString().slice(0, 10)}</span>
      <p>{doc.data.description}</p>
    </li>
  ))}
</ul>

<style>
  .recent-articles { list-style: none; padding: 0; display: grid; gap: 0.75rem; }
  .recent-articles li { border: 1px solid var(--sl-color-gray-5); border-radius: 0.75rem; padding: 0.8rem; }
  .recent-articles span { display: block; color: var(--sl-color-gray-3); font-size: 0.85rem; }
  .recent-articles p { margin: 0.25rem 0 0; }
</style>
