---
import { getCollection } from 'astro:content';

const { ids } = Astro.props as { ids: string[] };
const lang = Astro.currentLocale ?? 'zh-CN';
const isEn = lang === 'en';

const papers = await getCollection('papers');
const filtered = ids
  .map((id) => papers.find((p) => p.data.id === id))
  .filter(Boolean);

const heading = isEn ? 'References' : '本文引用论文';
---

{filtered.length > 0 && (
  <section class="paper-list">
    <h2>{heading}</h2>
    <ul>
      {filtered.map((paper) => (
        <li>
          <a href={isEn ? `/en/papers/${paper!.data.id}/` : `/papers/${paper!.data.id}/`}>
            {paper!.data.title ?? paper!.data.id}
          </a>
          {paper!.data.authors && paper!.data.authors.length > 0 && (
            <span class="meta">
              {' '}— {paper!.data.authors[0]}
              {paper!.data.authors.length > 1 ? ' et al.' : ''}
              {paper!.data.year ? ` (${paper!.data.year})` : ''}
            </span>
          )}
          <p class="tldr">{isEn ? paper!.data.tldr_en : paper!.data.tldr_zh}</p>
        </li>
      ))}
    </ul>
  </section>
)}

<style>
  .paper-list {
    margin-top: 2rem;
    border-top: 1px solid var(--sl-color-gray-5, #eee);
    padding-top: 1rem;
  }
  .paper-list ul {
    list-style: none;
    padding: 0;
  }
  .paper-list li {
    margin-bottom: 1rem;
  }
  .meta {
    color: var(--sl-color-gray-3, #666);
    font-size: 0.875rem;
  }
  .tldr {
    color: var(--sl-color-gray-2, #444);
    font-size: 0.875rem;
    margin: 0.25rem 0 0;
  }
</style>
