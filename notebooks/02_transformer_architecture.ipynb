   "source": [
    "# Transformer Architecture Deep Dive\n",
    "\n",
    "This notebook explores the complete transformer architecture with interactive visualizations.\n",
    "\n",
    "## Contents\n",
    "1. [Transformer Block Components](#transformer-block-components)\n",
    "2. [Multi-Head Attention Mechanism](#multi-head-attention-mechanism)\n",
    "3. [Positional Encoding](#positional-encoding)\n",
    "4. [Complete Forward Pass](#complete-forward-pass)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "import seaborn as sns\n",
    "from matplotlib.patches import FancyBboxPatch, FancyArrowPatch\n",
    "import matplotlib.patches as mpatches\n",
    "\n",
    "plt.style.use('seaborn-v0_8-whitegrid')\n",
    "sns.set_palette(\"husl\")\n",
    "\n",
    "print(\"✅ Environment ready!\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Complete Transformer Architecture Diagram\n",
    "\n",
    "Let's visualize the complete transformer architecture:"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def draw_transformer_architecture():\n",
    "    \"\"\"Draw the complete transformer architecture.\"\"\"\n",
    "    fig, ax = plt.subplots(figsize=(20, 14))\n",
    "    ax.set_xlim(0, 20)\n",
    "    ax.set_ylim(0, 14)\n",
    "    ax.axis('off')\n",
    "    \n",
    "    # Title\n",
    "    ax.text(10, 13.5, 'Transformer Architecture', fontsize=24, fontweight='bold', \n",
    "            ha='center', va='center')\n",
    "    \n",
    "    # Input Embedding\n",
    "    input_box = FancyBboxPatch((1, 11), 3, 1, boxstyle=\"round,pad=0.1\", \n",
    "                               facecolor='#FFB6C1', edgecolor='black', linewidth=2)\n",
    "    ax.add_patch(input_box)\n",
    "    ax.text(2.5, 11.5, 'Input\\nEmbedding', ha='center', va='center', fontsize=11, fontweight='bold')\n",
    "    \n",
    "    # Positional Encoding\n",
    "    pos_box = FancyBboxPatch((5, 11), 3, 1, boxstyle=\"round,pad=0.1\", \n",
    "                            facecolor='#98FB98', edgecolor='black', linewidth=2)\n",
    "    ax.add_patch(pos_box)\n",
    "    ax.text(6.5, 11.5, 'Positional\\nEncoding', ha='center', va='center', fontsize=11, fontweight='bold')\n",
    "    \n",
    "    # Encoder Stack (x6)\n",
    "    for i in range(3):\n",
    "        y_pos = 9 - i * 2.5\n",
    "        \n",
    "        # Multi-Head Attention\n",
    "        mha_box = FancyBboxPatch((2, y_pos), 4, 0.8, boxstyle=\"round,pad=0.05\", \n",
    "                                facecolor='#87CEEB', edgecolor='black', linewidth=1.5)\n",
    "        ax.add_patch(mha_box)\n",
    "        ax.text(4, y_pos + 0.4, 'Multi-Head Attention', ha='center', va='center', \n",
    "                fontsize=9, fontweight='bold')\n",
    "        \n",
    "        # Add & Norm\n",
    "        add_norm_box = FancyBboxPatch((2, y_pos - 0.5), 4, 0.4, boxstyle=\"round,pad=0.02\", \n",
    "                                     facecolor='#F0E68C', edgecolor='black', linewidth=1)\n",
    "        ax.add_patch(add_norm_box)\n",
    "        ax.text(4, y_pos - 0.3, 'Add & Norm', ha='center', va='center', fontsize=8)\n",
    "        \n",
    "        # Feed Forward\n",
    "        ff_box = FancyBboxPatch((2, y_pos - 1.2), 4, 0.6, boxstyle=\"round,pad=0.05\", \n",
    "                               facecolor='#DDA0DD', edgecolor='black', linewidth=1.5)\n",
    "        ax.add_patch(ff_box)\n",
    "        ax.text(4, y_pos - 0.9, 'Feed Forward', ha='center', va='center', \n",
    "                fontsize=9, fontweight='bold')\n",
    "        \n",
    "        # Add & Norm (second)\n",
    "        add_norm_box2 = FancyBboxPatch((2, y_pos - 1.7), 4, 0.4, boxstyle=\"round,pad=0.02\", \n",
    "                                      facecolor='#F0E68C', edgecolor='black', linewidth=1)\n",
    "        ax.add_patch(add_norm_box2)\n",
    "        ax.text(4, y_pos - 1.5, 'Add & Norm', ha='center', va='center', fontsize=8)\n",
    "    \n",
    "    # Output\n",
    "    output_box = FancyBboxPatch((2, -0.5), 4, 0.8, boxstyle=\"round,pad=0.1\", \n",
    "                               facecolor='#FFA07A', edgecolor='black', linewidth=2)\n",
    "    ax.add_patch(output_box)\n",
    "    ax.text(4, -0.1, 'Output', ha='center', va='center', fontsize=12, fontweight='bold')\n",
    "    \n",
    "    # Arrows (simplified)\n",
    "    ax.annotate('', xy=(2.5, 11), xytext=(2.5, 11.5),\n",
    "                arrowprops=dict(arrowstyle='->', lw=2, color='black'))\n",
    "    \n",
    "    # Legend\n",
    "    legend_elements = [\n",
    "        mpatches.Patch(facecolor='#87CEEB', label='Multi-Head Attention'),\n",
    "        mpatches.Patch(facecolor='#DDA0DD', label='Feed Forward'),\n",
    "        mpatches.Patch(facecolor='#F0E68C', label='Add & Norm'),\n",
    "        mpatches.Patch(facecolor='#FFB6C1', label='Embedding'),\n",
    "        mpatches.Patch(facecolor='#98FB98', label='Positional Encoding')\n",
    "    ]\n",
    "    ax.legend(handles=legend_elements, loc='upper right', bbox_to_anchor=(0.98, 0.98), fontsize=9)\n",
    "    \n",
    "    plt.tight_layout()\n",
    "    return fig, ax\n",
    "\n",
    "# Draw the architecture\n",
    "fig, ax = draw_transformer_architecture()\n",
    "plt.show()"
   ]
  }
 ],
