   "source": [
    "# Positional Encoding Visualization\n",
    "\n",
    "This notebook visualizes different positional encoding schemes used in transformer models.\n",
    "\n",
    "## Topics Covered:\n",
    "1. [Sinusoidal Positional Encoding](#sinusoidal-positional-encoding)\n",
    "2. [Learned Positional Embeddings](#learned-positional-embeddings)\n",
    "3. [Rotary Position Embedding (RoPE)](#rotary-position-embedding-rope)\n",
    "4. [ALiBi (Attention with Linear Biases)](#alibi)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "import seaborn as sns\n",
    "\n",
    "# Set style\n",
    "sns.set_style(\"whitegrid\")\n",
    "plt.rcParams['figure.figsize'] = (14, 6)\n",
    "\n",
    "print(\"✅ Environment ready!\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Sinusoidal Positional Encoding\n",
    "\n",
    "The original Transformer uses sinusoidal functions of different frequencies:\n",
    "\n",
    "$$PE_{(pos, 2i)} = \\sin(pos / 10000^{2i/d_{model}})$$\n",
    "\n",
    "$$PE_{(pos, 2i+1)} = \\cos(pos / 10000^{2i/d_{model}})$$"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def get_sinusoidal_positional_encoding(seq_len, d_model):\n",
    "    \"\"\"Generate sinusoidal positional encoding.\"\"\"\n",
    "    position = np.arange(seq_len)[:, np.newaxis]\n",
    "    div_term = np.exp(np.arange(0, d_model, 2) * -(np.log(10000.0) / d_model))\n",
    "    \n",
    "    pe = np.zeros((seq_len, d_model))\n",
    "    pe[:, 0::2] = np.sin(position * div_term)\n",
    "    pe[:, 1::2] = np.cos(position * div_term)\n",
    "    \n",
    "    return pe\n",
    "\n",
    "# Generate positional encodings\n",
    "seq_len, d_model = 100, 512\n",
    "pe = get_sinusoidal_positional_encoding(seq_len, d_model)\n",
    "\n",
    "# Visualize\n",
    "fig, axes = plt.subplots(2, 2, figsize=(16, 10))\n",
    "\n",
    "# 1. Heatmap\n",
    "ax1 = axes[0, 0]\n",
    "im1 = ax1.imshow(pe.T, aspect='auto', cmap='RdBu_r', vmin=-1, vmax=1)\n",
    "ax1.set_xlabel('Position')\n",
    "ax1.set_ylabel('Dimension')\n",
    "ax1.set_title('Sinusoidal Positional Encoding Heatmap')\n",
    "plt.colorbar(im1, ax=ax1, fraction=0.046)\n",
    "\n",
    "# 2. Sample dimensions\n",
    "ax2 = axes[0, 1]\n",
    "positions = np.arange(seq_len)\n",
    "for i in [0, 1, 10, 20, 50, 100]:\n",
    "    if i < d_model:\n",
    "        ax2.plot(positions, pe[:, i], label=f'Dim {i}', linewidth=2)\n",
    "ax2.set_xlabel('Position')\n",
    "ax2.set_ylabel('Encoding Value')\n",
    "ax2.set_title('Sample Dimensions Over Positions')\n",
    "ax2.legend(loc='upper right', ncol=2)\n",
    "ax2.grid(True, alpha=0.3)\n",
    "\n",
    "# 3. Dot product between positions (shows relative position encoding)\n",
    "ax3 = axes[1, 0]\n",
    "dot_products = pe @ pe.T\n",
    "im3 = ax3.imshow(dot_products[:50, :50], cmap='viridis', aspect='auto')\n",
    "ax3.set_xlabel('Position')\n",
    "ax3.set_ylabel('Position')\n",
    "ax3.set_title('Dot Product Between Positions (Self-Similarity)')\n",
    "plt.colorbar(im3, ax=ax3, fraction=0.046)\n",
    "\n",
    "# 4. Frequency analysis\n",
    "ax4 = axes[1, 1]\n",
    "wavelengths = []\n",
    "for i in range(0, d_model, 2):\n",
    "    wavelength = 2 * np.pi / (1 / (10000 ** (i / d_model)))\n",
    "    wavelengths.append(wavelength)\n",
    "ax4.bar(range(len(wavelengths)), wavelengths, color='steelblue', edgecolor='navy')\n",
    "ax4.set_xlabel('Dimension Pair Index')\n",
    "ax4.set_ylabel('Wavelength')\n",
    "ax4.set_title('Wavelength of Each Dimension Pair')\n",
    "ax4.set_yscale('log')\n",
    "ax4.grid(True, alpha=0.3)\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.savefig('positional_encoding_analysis.png', dpi=150, bbox_inches='tight')\n",
    "plt.show()\n",
    "\n",
    "print(\"✅ Positional encoding visualization complete!\")"
   ]
  }
